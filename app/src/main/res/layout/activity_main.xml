<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0B0B0B"
    android:padding="24dp">

    <!-- Логотип (если есть файл @drawable/star_wars_logo, иначе замените на TextView с символом) -->
    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/star_wars_logo"
        android:contentDescription="Star Wars Logo"
        android:layout_marginBottom="32dp"/>

    <!-- Главный заголовок -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STAR WARS"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#FFE81F"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.15"
        android:shadowColor="#FFE81F"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="12"
        android:layout_marginBottom="8dp"/>

    <!-- Подзаголовок -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ВИКТОРИНА"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.3"
        android:fontFamily="sans-serif-light"
        android:layout_marginBottom="48dp"/>

    <!-- Декоративная золотая линия -->
    <View
        android:layout_width="120dp"
        android:layout_height="2dp"
        android:background="#FFE81F"
        android:layout_marginBottom="48dp"/>

    <!-- Кнопка НАЧАТЬ -->
    <Button
        android:id="@+id/startButton"
        android:layout_width="240dp"
        android:layout_height="64dp"
        android:text="НАЧАТЬ ИГРУ"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:background="@drawable/button_gold_bg"
        android:elevation="8dp"
        android:fontFamily="sans-serif-medium"
        android:stateListAnimator="@null"/>

    <!-- Кнопка РЕДАКТИРОВАТЬ -->
    <Button
        android:id="@+id/editBtn"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:text="РЕДАКТИРОВАТЬ ВОПРОСЫ"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFE81F"
        android:background="@drawable/button_outline_bg"
        android:elevation="4dp"
        android:layout_marginTop="24dp"
        android:stateListAnimator="@null"/>

    <!-- Копирайт -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="© 2026 Star Wars Quiz"
        android:textSize="12sp"
        android:textColor="#555555"
        android:layout_marginTop="72dp"/>

</LinearLayout>